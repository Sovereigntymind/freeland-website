{% block content %}

  <section class="blog-hero" aria-label="Blog hero">
    <div class="blog-hero-inner">
      <span class="badge">From the Team</span>
      <h1>Marketing Insights &amp;<br /><span class="red-text">Growth Strategies</span></h1>
      <p>Real advice for Florida small businesses looking to grow with social media, AI automation, and SEO. No fluff. Just what works.</p>
    </div>
  </section>

  <div class="wave" style="background:#05091a"><svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,0 C360,60 1080,60 1440,0 L1440,60 L0,60 Z" fill="#f5f6fb"/></svg></div>

  <section class="blog-section" aria-label="Blog posts">
    <div class="container">
      <span class="section-label">Latest Articles</span>
      <h2 class="section-title" style="margin-bottom:48px;">Marketing Tips That Drive Real Results</h2>
      <div class="blog-grid">

        <a href="/blog/how-florida-small-businesses-can-dominate-social-media-2026/" class="blog-card">
          <div class="blog-card-img"><img src="/blog/images/Yz9jwTyJpb06TSV6U6MHN_JCkv8NwO.jpg" alt="Florida business owner filming social media content" width="400" height="180" /></div>
