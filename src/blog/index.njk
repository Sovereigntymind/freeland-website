{% extends "base.njk" %}

{% block head %}
  <title>Marketing Blog | Freeland Marketing &amp; Entertainment | Palm Coast, FL</title>
  <meta name="description" content="Marketing tips, AI automation insights, and SEO strategies for Florida small businesses. Real advice from Freeland Marketing &amp; Entertainment in Palm Coast, FL." />
  <meta name="keywords" content="marketing blog Florida, small business marketing tips, AI automation guide, SEO Florida, social media tips Palm Coast" />
  <meta name="author" content="Kevin Freeland" />
  <link rel="canonical" href="https://freelandme.com/blog/" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://freelandme.com/blog/" />
  <meta property="og:title" content="Marketing Blog | Freeland Marketing &amp; Entertainment" />
  <meta property="og:description" content="Marketing tips, AI automation insights, and growth strategies for Florida small businesses." />
