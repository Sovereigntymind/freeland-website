{% block content %}

  <section class="post-header">
    <div class="post-header-inner">
      <a href="/" class="post-breadcrumb">&larr; Back to Home</a>
      <span class="blog-category">Services</span>
      <h1>Digital Marketing Services for Small Businesses</h1>
      <p style="color:#ccc;margin-top:0.75rem;font-size:1.05rem;">Everything your business needs to get found, generate leads, and grow revenue — under one roof. Serving small businesses nationwide from our headquarters in Palm Coast, FL.</p>
    </div>
  </section>

  <div class="post-body" style="max-width:900px;margin:3rem auto;padding:0 1.5rem;">

    <div class="cards" style="margin-top:2rem;">

      <article class="card">
        <div class="card-icon" aria-hidden="true">📱</div>
        <h2 style="font-size:1.2rem;">Social Media Management</h2>
        <p>Done-for-you content creation, scheduling, community management, and reporting across Instagram, Facebook, and TikTok.</p>
        <a href="/services/social-media-management/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">💰</div>
        <h2 style="font-size:1.2rem;">Google Ads Management</h2>
        <p>High-intent paid search campaigns that put your business at the top of Google when customers are ready to buy.</p>
        <a href="/services/google-ads-management/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">🎯</div>
        <h2 style="font-size:1.2rem;">Meta Ads (Facebook &amp; Instagram)</h2>
        <p>Precision-targeted Facebook and Instagram campaigns that reach your ideal audience and generate leads on demand.</p>
        <a href="/services/meta-ads/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">🔍</div>
        <h2 style="font-size:1.2rem;">SEO Services</h2>
        <p>Local SEO, Google Business Profile optimization, and content strategy that builds organic traffic that compounds over time.</p>
        <a href="/services/seo/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">🤖</div>
        <h2 style="font-size:1.2rem;">AI Automation</h2>
        <p>Email sequences, booking systems, social scheduling, and lead nurturing that run 24/7 without extra staff.</p>
        <a href="/services/ai-automation/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">🔗</div>
        <h2 style="font-size:1.2rem;">CRM Automation</h2>
        <p>Automated lead follow-up, pipeline management, and nurturing sequences that convert more leads without manual effort.</p>
        <a href="/services/crm-automation/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

      <article class="card">
        <div class="card-icon" aria-hidden="true">🌐</div>
        <h2 style="font-size:1.2rem;">Website Design</h2>
        <p>Fast, mobile-friendly, conversion-focused websites built for small businesses — with SEO built in from day one.</p>
        <a href="/services/website-design/" style="color:var(--blue);font-weight:600;text-decoration:none;">Learn More &rarr;</a>
      </article>

    </div>

    <div class="post-cta-box" style="margin-top:3rem;">
      <h3>Not Sure Which Service You Need?</h3>
      <p>Book a free 30-minute strategy call. We will audit your current marketing and recommend exactly which services will drive the most growth for your business.</p>
      <a href="/#contact" class="btn-primary btn-large">Get My Free Strategy Call &rarr;</a>
    </div>

  </div>

{% endblock %}
