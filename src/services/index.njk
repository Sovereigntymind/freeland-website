  <meta name="author" content="Kevin Freeland" />
  <link rel="canonical" href="https://freelandme.com/services/" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://freelandme.com/services/" />
  <meta property="og:title" content="Marketing Services for Small Businesses | Freeland Marketing" />
  <meta property="og:description" content="Social media management, Google & Meta Ads, SEO, AI automation, CRM, and website design for small businesses nationwide. Serving all 50 states." />
  <meta property="og:image" content="https://freelandme.com/images/hero-bg.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="624" />
  <meta property="og:image:alt" content="Freeland Marketing Services for Small Businesses Nationwide" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Freeland Marketing &amp; Entertainment" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Marketing Services for Small Businesses | Freeland Marketing" />
  <meta name="twitter:description" content="Social media, ads, SEO, AI automation & web design for small businesses nationwide." />
