  <meta name="twitter:image:alt" content="Freeland Marketing Services for Small Businesses Nationwide" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freelandme.com/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://freelandme.com/services/" }
    ]
  }
