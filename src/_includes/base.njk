  <style>@font-face{font-family:'Inter';font-style:normal;font-weight:400 800;font-display:swap;src:url('/fonts/inter-latin.woff2') format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{font-family:'Inter',sans-serif;color:#0d0d1e;background:#fff;line-height:1.6;overflow-x:hidden}.skip-nav{position:absolute;top:-100%;left:16px;background:#0033A0;color:#fff;padding:12px 24px;border-radius:0 0 8px 8px;font-weight:700;font-size:.9rem;z-index:99999;text-decoration:none;transition:top .2s}.skip-nav:focus{top:0}body>header{position:fixed;top:16px;left:50%;transform:translateX(-50%);width:calc(100% - 48px);max-width:1100px;z-index:9999;background:transparent;border:1px solid rgba(255,255,255,.1);border-radius:100px;transition:background .3s,box-shadow .3s,border-radius .3s;overflow:hidden}body>header::before{content:'';position:absolute;inset:0;background:rgba(5,9,26,.7);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);z-index:-1;border-radius:inherit}.nav-inner{padding:0 28px;height:62px;display:flex;align-items:center;justify-content:space-between}.logo img{height:38px;width:auto;display:block}.logo{text-decoration:none}.nav-links{list-style:none;display:flex;align-items:center;gap:28px}.nav-links a{color:rgba(255,255,255,.75);text-decoration:none;font-size:.88rem;font-weight:500}.btn-nav{background:linear-gradient(135deg,#BF0A30,#8b0022)!important;color:#fff!important;padding:9px 22px;border-radius:100px!important;font-weight:700!important;font-size:.85rem!important}.mobile-menu-btn{display:none;background:none;border:none;color:#fff;font-size:1.6rem;cursor:pointer;padding:8px}.hero{min-height:100vh;background:radial-gradient(ellipse at 50% 50%,rgba(5,9,26,.55) 0%,rgba(5,9,26,.82) 60%,rgba(5,9,26,.97) 100%),url('images/hero-bg.avif') center/cover no-repeat;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 24px 100px;position:relative;overflow:hidden}.hero-content{position:relative;max-width:880px}.hero-logo{width:min(520px,80vw);height:auto;margin:0 auto 32px;display:block;filter:drop-shadow(0 4px 32px rgba(0,0,0,.6))}.hero h1{font-size:clamp(2.8rem,6vw,5.2rem);font-weight:800;color:#fff;line-height:1.05;margin-bottom:24px;letter-spacing:-1px}.red-text{background:linear-gradient(135deg,#ff4d6d,#BF0A30);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.btn-primary{background:linear-gradient(135deg,#BF0A30,#8b0022);color:#fff;padding:14px 32px;border-radius:100px;font-weight:700;font-size:.95rem;text-decoration:none;border:none;cursor:pointer;display:inline-block}.btn-primary.btn-large{padding:16px 40px;font-size:1rem}.btn-secondary{background:rgba(255,255,255,.05);color:#fff;padding:14px 32px;border-radius:100px;font-weight:600;font-size:.95rem;text-decoration:none;border:1px solid rgba(255,255,255,.15);display:inline-block}.float-cta{position:fixed;bottom:32px;right:32px;opacity:0;pointer-events:none;z-index:99}@media(max-width:768px){.nav-links{display:none}.mobile-menu-btn{display:block}}</style>
