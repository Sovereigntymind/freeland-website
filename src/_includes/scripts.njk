<script>
  function toggleMenu() {
    document.getElementById('mobileNav').classList.toggle('open');
    document.querySelector('body > header').classList.toggle('menu-open');
  }
  window.addEventListener('scroll', () => {
    document.querySelector('header').classList.toggle('scrolled', window.scrollY > 40);
  });
  const floatBtn = document.querySelector('.float-cta');
  if (floatBtn) {
    window.addEventListener('scroll', () => {
      floatBtn.classList.toggle('visible', window.scrollY > 400);
    });
  }
</script>
