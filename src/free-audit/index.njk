    .audit-urgency { text-align: center; margin: 1rem 0 0; padding: 0.6rem 1rem; background: rgba(191,10,48,0.1); border: 1px solid rgba(191,10,48,0.2); border-radius: 8px; font-size: 0.85rem; color: #ff6b7f; }
    .audit-check-list { list-style: none; padding: 0; margin: 0; }
    .audit-check-list li { padding: 0.6rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; gap: 0.65rem; align-items: flex-start; }
    .audit-check-list li:last-child { border-bottom: none; }
    .audit-check { color: #4d88ff; font-weight: 700; flex-shrink: 0; font-size: 1.1rem; line-height: 1.4; }
    .audit-steps { counter-reset: steps; list-style: none; padding: 0; }
