  <style>
    .audit-trust { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; padding: 1rem 1.25rem; background: rgba(77,136,255,0.08); border: 1px solid rgba(77,136,255,0.18); border-radius: 12px; }
