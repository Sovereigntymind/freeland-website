    .audit-steps li:last-child { border-bottom: none; }
    .audit-steps li::before { content: counter(steps); display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: rgba(77,136,255,0.12); border: 1px solid rgba(77,136,255,0.25); color: #4d88ff; font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
