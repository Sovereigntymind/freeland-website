  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MarketingAgency",
    "name": "Freeland Marketing & Entertainment",
    "url": "https://freelandme.com",
    "email": "kevin@freelandme.com",
    "description": "National marketing and AI consulting agency specializing in social media management, paid ads, AI automation, AI workflow design, AI consulting, CRM, SEO, and website builds — serving businesses from startups to corporations across the US.",
    "founder": { "@type": "Person", "name": "Kevin Freeland" },
    "address": { "@type": "PostalAddress", "addressLocality": "Palm Coast", "addressRegion": "FL", "addressCountry": "US" },
    "logo": { "@type": "ImageObject", "url": "https://freelandme.com/images/logo.webp" },
    "areaServed": "United States",
    "sameAs": ["https://facebook.com/FreelandMarketingandEntertainment", "https://instagram.com/freelandmarketing"]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What types of businesses do you work with?",
        "acceptedAnswer": { "@type": "Answer", "text": "We work with businesses of all sizes — from local shops, restaurants, and entrepreneurs to mid-size companies and corporations generating over $1 million in revenue. We also provide AI consulting and custom AI workflow design for businesses looking to integrate AI into their operations. If you want to grow, automate, or scale — we can help." }
      },
      {
        "@type": "Question",
        "name": "How soon will I see results?",
        "acceptedAnswer": { "@type": "Answer", "text": "Many clients see results within the first 30 days. Our client Tokyo Japanese Steakhouse saw same-day bookings from their first video campaign. Timelines vary by service, but we move fast and focus on measurable ROI from day one." }
      },
      {
        "@type": "Question",
        "name": "What is Freeland Automation?",
        "acceptedAnswer": { "@type": "Answer", "text": "Freeland Automation is our AI-powered service suite that automates your business operations — CRM follow-ups, email sequences, social scheduling, call-center booking, lead nurturing, and more. It makes your business run 24/7 without extra staff." }
      },
      {
        "@type": "Question",
        "name": "Do you require long-term contracts?",
        "acceptedAnswer": { "@type": "Answer", "text": "No long-term contracts required. We earn your business every month through results. We're confident enough in what we deliver that we don't need to lock you in." }
      },
      {
        "@type": "Question",
        "name": "How much do your services cost?",
        "acceptedAnswer": { "@type": "Answer", "text": "Pricing is tailored to your business goals and the services you need. We offer flexible packages and have worked with businesses at all stages — from startups to established brands. Book a free consultation and we'll build a plan that fits your budget." }
      },
      {
        "@type": "Question",
        "name": "What makes Freeland Marketing different from other agencies?",
        "acceptedAnswer": { "@type": "Answer", "text": "We're not a faceless agency. Kevin personally visits clients, films content, and stays hands-on throughout. We combine creator energy, community roots, and an ROI mindset that most agencies lack. Our clients' success stories speak for themselves." }
      },
      {
        "@type": "Question",
        "name": "Where do you work with businesses?",
        "acceptedAnswer": { "@type": "Answer", "text": "We work with businesses anywhere in the US. Our digital services, paid ads, and automation systems are location-independent — so whether you're in New York, LA, or anywhere in between, we can help you grow." }
      },
      {
        "@type": "Question",
        "name": "Can you handle both my marketing AND automation?",
        "acceptedAnswer": { "@type": "Answer", "text": "Absolutely — that's our specialty. We offer full-service packages that combine social media management, paid ads, and Freeland Automation so everything works together as one growth engine." }
      }
    ]
  }
  </script>

  <link rel="preload" as="image" href="/images/hero-bg.webp" type="image/webp" />
{% endblock %}

