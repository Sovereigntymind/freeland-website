{% extends "base.njk" %}

{% block head %}
  <title>Client Case Studies | Freeland Marketing</title>
  <meta name="description" content="Real results from real businesses. See how Freeland Marketing helped clients improve SEO rankings, recover leads, and grow revenue with marketing and AI automation." />
  <meta name="author" content="Kevin Freeland" />
  <link rel="canonical" href="https://freelandme.com/case-studies/" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://freelandme.com/case-studies/" />
  <meta property="og:title" content="Client Case Studies | Freeland Marketing" />
  <meta property="og:description" content="Real results from real businesses. See how Freeland Marketing helped clients improve SEO rankings, recover leads, and grow revenue." />
  <meta property="og:image" content="https://freelandme.com/images/hero-bg.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="624" />
  <meta property="og:image:alt" content="Freeland Marketing Client Case Studies" />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Freeland Marketing &amp; Entertainment" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Client Case Studies | Freeland Marketing" />
  <meta name="twitter:description" content="Real results from real businesses. See how Freeland Marketing helped clients grow with marketing and AI automation." />
  <meta name="twitter:image" content="https://freelandme.com/images/hero-bg.jpg" />
  <meta name="twitter:image:alt" content="Freeland Marketing Client Case Studies" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://freelandme.com/" },
      { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": "https://freelandme.com/case-studies/" }
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Client Case Studies",
    "description": "Real results from real businesses. See how Freeland Marketing helped clients improve SEO rankings, recover leads, and grow revenue with marketing and AI automation.",
    "url": "https://freelandme.com/case-studies/",
    "publisher": {
      "@type": "MarketingAgency",
      "name": "Freeland Marketing & Entertainment",
      "url": "https://freelandme.com"
    }
  }
  </script>
{% endblock %}

{% block content %}

  <section class="post-header">
    <div class="post-header-inner">
      <a href="/" class="post-breadcrumb">&larr; Back to Home</a>
      <span class="blog-category">Results</span>
      <h1>Client Success Stories</h1>
      <p style="color:#ccc;margin-top:0.75rem;font-size:1.05rem;">Real results from real businesses. Every case study below is a documented engagement with measurable outcomes.</p>
    </div>
  </section>

  <div class="post-body" style="max-width:900px;margin:3rem auto;padding:0 1.5rem;">

    <div class="cards" style="margin-top:1rem;">

      <article class="card" style="text-align:left;">
        <span class="blog-category">Custom Wood Carving / E-commerce</span>
        <h3>Joe Tiki Custom Wood Carving</h3>
        <p><strong>Challenge:</strong> Small garage hobby with no online presence — no website, no social media, no marketing of any kind.</p>
        <p><strong>Result:</strong> <span style="color:var(--blue);font-weight:700;">10x business growth in one year</span></p>
        <p style="font-size:0.85rem;color:#888;">Services: Social media, content creation, business consulting</p>
        <p style="font-size:0.85rem;color:#aaa;font-style:italic;">Full case study coming soon</p>
      </article>

      <article class="card" style="text-align:left;">
        <span class="blog-category">Restaurant</span>
        <h3>Tokyo Japanese Steakhouse</h3>
        <p><strong>Challenge:</strong> Needed more bookings and foot traffic in a competitive restaurant market.</p>
        <p><strong>Result:</strong> <span style="color:var(--blue);font-weight:700;">Same-day bookings from first video campaign</span></p>
        <p style="font-size:0.85rem;color:#888;">Services: Video content, social media</p>
        <p style="font-size:0.85rem;color:#aaa;font-style:italic;">Full case study coming soon</p>
      </article>

      <article class="card" style="text-align:left;">
        <span class="blog-category">Events &amp; Hospitality</span>
        <h3>Coming Soon — SEO Remediation</h3>
        <p><strong>Challenge:</strong> Hacked website, destroyed SEO rankings, security vulnerabilities across the entire domain.</p>
        <p><strong>Result:</strong> <span style="color:var(--blue);font-weight:700;">In progress — Phase 1 remediation underway</span></p>
        <p style="font-size:0.85rem;color:#888;">Services: SEO audit, security cleanup, technical SEO</p>
        <p style="font-size:0.85rem;color:#aaa;font-style:italic;">Check back for the full case study</p>
      </article>

    </div>

    <div class="post-callout" style="margin-top:3rem;">
      <p>Every client engagement starts with a conversation. There's no cookie-cutter approach — we build the strategy around your business.</p>
    </div>

    <div class="post-cta-box">
      <h3>Want to Be Our Next Success Story?</h3>
      <p>Get a free SEO audit or book a strategy call — and let's build something that actually moves the needle for your business.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
        <a href="/seo-audit/" class="btn-primary btn-large">Get a Free SEO Audit &rarr;</a>
        <a href="/#contact" class="btn-primary btn-large" style="background:transparent;border:2px solid var(--blue);color:var(--blue);">Book a Strategy Call &rarr;</a>
      </div>
    </div>

  </div>

{% endblock %}
