        <p id="gbp-audit-error" role="alert" style="display:none;margin-top:0.75rem;padding:0.75rem 1rem;background:rgba(191,10,48,0.12);border:1px solid rgba(191,10,48,0.3);border-radius:8px;color:#ff6b7f;font-size:0.88rem;"></p>
