    }
    .links-avatar {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      border: 3px solid #4d88ff;
      object-fit: cover;
      box-shadow: 0 0 20px rgba(77,136,255,0.3);
    }
    .links-name {
