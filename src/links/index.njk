    .lp-result { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.5rem; }
    .lp-result:last-child { margin-bottom: 0; }
    .lp-result-num { font-size: 1rem; font-weight: 700; color: #4d88ff; white-space: nowrap; }
    .lp-result-text { font-size: 0.85rem; color: #b0b0c0; }

    /* Services pills */
    .lp-services { display: flex; flex-wrap: wrap; gap: 0.4rem; justify-content: center; margin-bottom: 1.25rem; }
    .lp-pill { padding: 0.35rem 0.7rem; background: rgba(77,136,255,0.1); border: 1px solid rgba(77,136,255,0.2); border-radius: 100px; font-size: 0.75rem; color: #8ab4ff; font-weight: 500; white-space: nowrap; }

    /* Social icons */
    .lp-social { display: flex; gap: 0.7rem; justify-content: center; margin-bottom: 1.5rem; }
    .lp-social a { display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 50%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); color: #fff; transition: background 0.2s, transform 0.15s; }
    .lp-social a:hover { background: rgba(255,255,255,0.14); transform: translateY(-2px); }
    .lp-social svg { width: 20px; height: 20px; fill: #fff; }

    /* Footer */
    .lp-foot { text-align: center; }
    .lp-foot a { color: rgba(255,255,255,0.3); font-size: 0.78rem; text-decoration: none; }
    .lp-foot a:hover { color: rgba(255,255,255,0.6); }

    @media (max-width: 520px) {
