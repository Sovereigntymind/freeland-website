      line-height: 1.4;
    }
    .links-list {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }
    .link-item {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      padding: 1rem 1.25rem;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 12px;
      color: #ffffff;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
      text-align: center;
    }
    .link-item:hover {
      transform: translateY(-2px);
      background: rgba(255,255,255,0.14);
      box-shadow: 0 6px 24px rgba(0,0,0,0.3);
      color: #ffffff;
    }
    .link-item-cta {
      background: linear-gradient(135deg, #BF0A30, #d41a3e);
      border-color: transparent;
      font-size: 1.05rem;
      padding: 1.1rem 1.25rem;
    }
    .link-item-cta:hover {
      background: linear-gradient(135deg, #d41a3e, #e62a4e);
      box-shadow: 0 6px 24px rgba(191,10,48,0.35);
    }
    .links-divider {
      width: 60px;
      height: 1px;
      background: rgba(255,255,255,0.12);
      margin: 0.75rem auto;
    }
    .links-social {
      display: flex;
      gap: 0.85rem;
      margin-top: 1.5rem;
      justify-content: center;
    }
    .links-social a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      color: #ffffff;
      transition: background 0.2s, transform 0.2s;
    }
    .links-social a:hover {
      background: rgba(255,255,255,0.18);
      transform: translateY(-2px);
    }
    .links-social svg {
      width: 22px;
      height: 22px;
      fill: #ffffff;
    }
    .links-footer {
      margin-top: 2.5rem;
      text-align: center;
    }
    .links-footer a {
      color: rgba(255,255,255,0.35);
      font-size: 0.8rem;
      text-decoration: none;
      letter-spacing: 0.02em;
    }
    .links-footer a:hover { color: rgba(255,255,255,0.6); }
    @media (max-width: 520px) {
      .links-page { padding: 5rem 1.25rem 3rem; }
      .links-avatar { width: 90px; height: 90px; }
      .links-name { font-size: 1.2rem; }
    }
  </style>
{% endblock %}

