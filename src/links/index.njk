    .lp-cta-title { font-size: 1.1rem; font-weight: 700; color: #fff; }
    .lp-cta-sub { font-size: 0.82rem; color: rgba(255,255,255,0.8); margin-top: 0.3rem; }

    /* Link items */
    .lp-links { display: flex; flex-direction: column; gap: 0.55rem; margin-bottom: 1.25rem; }
    .lp-link { display: block; padding: 0.85rem 1rem; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; color: #fff; text-decoration: none; font-weight: 600; font-size: 0.92rem; text-align: center; transition: transform 0.15s, background 0.15s; }
    .lp-link:hover { transform: translateY(-1px); background: rgba(255,255,255,0.11); color: #fff; }

